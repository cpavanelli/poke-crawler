# Copy to .env and fill in. See FRD.md §3.

# Discord incoming webhook (required)
DISCORD_WEBHOOK_URL=

# Paths
CARDS_CONFIG_PATH=cards.json
DATABASE_PATH=watcher.db

# Scheduling / pacing (seconds unless noted)
CHECK_INTERVAL_MINUTES=15
REQUEST_DELAY_SECONDS=30
SPRITE_REQUEST_DELAY_SECONDS=2

# HTTP
HTTP_TIMEOUT_SECONDS=20
USER_AGENT=PokemonCardWatcher/1.0

# Notifications
SEND_INITIAL_BASELINE_NOTIFICATION=false

# Logging (rotating file handler — FRD §16)
LOG_MAX_BYTES=1048576
LOG_BACKUP_COUNT=5
